# Konfiguracja Firebase dla Erasmus Planner Buddy
# Skopiuj ten plik jako .env lub .env.local i uzupełnij swoimi danymi z konsoli Firebase.

VITE_FIREBASE_API_KEY=twoj_api_key_tutaj
VITE_FIREBASE_AUTH_DOMAIN=twoj-projekt.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=twoj-projekt-id
VITE_FIREBASE_STORAGE_BUCKET=twoj-projekt.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
